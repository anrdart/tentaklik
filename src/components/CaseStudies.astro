---
import { caseStudies, portfolioSection } from '@/data/content';
import T from './T.astro';
---

<section id="portfolio" class="py-12 md:py-20 bg-white dark:bg-dark-card">
  <div class="max-w-container mx-auto px-5 md:px-10">
    <div class="reveal">
      <p class="eyebrow"><T id={portfolioSection.eyebrow} en={portfolioSection.eyebrowEn} /></p>
      <h2 class="section-title max-w-xl dark:text-white"><T id={portfolioSection.title} en={portfolioSection.titleEn} /></h2>
      <p class="section-sub dark:text-text-muted"><T id={portfolioSection.sub} en={portfolioSection.subEn} /></p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
      {caseStudies.map((cs, i) => (
        <article
          class="reveal flex flex-col sm:flex-row items-start sm:items-center gap-4 border border-border dark:border-dark-border rounded-2xl p-5 md:p-7 bg-white dark:bg-dark hover:border-primary hover:-translate-y-1 transition-all duration-200 cursor-default"
          style={`transition-delay: ${i * 60}ms`}
        >
          <div class="w-16 h-16 sm:w-20 sm:h-20 shrink-0 bg-primary-light rounded-2xl flex items-center justify-center text-3xl sm:text-4xl">
            {cs.thumb}
          </div>
          <div>
            <h3 class="text-base font-extrabold text-dark dark:text-white mb-1">{cs.name}</h3>
            <p class="text-xs font-semibold text-text-muted mb-3">
              <T id={cs.industry} en={cs.industryEn} />
            </p>
            <span class="inline-block bg-primary-light text-primary text-[13px] font-extrabold rounded-lg px-3 py-1">
              <T id={cs.metric} en={cs.metricEn} />
            </span>
            <p class="text-[13px] text-text-body dark:text-text-muted leading-relaxed mt-2">
              <T id={cs.desc} en={cs.descEn} />
            </p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
