---
import { pricingPlans, pricingSection, siteConfig } from '@/data/content';
import T from './T.astro';
---

<section id="harga" class="py-20 bg-white dark:bg-dark-card">
  <div class="max-w-container mx-auto px-10">
    <div class="reveal">
      <p class="eyebrow"><T id={pricingSection.eyebrow} en={pricingSection.eyebrowEn} /></p>
      <h2 class="section-title dark:text-white"><T id={pricingSection.title} en={pricingSection.titleEn} /></h2>
      <p class="section-sub dark:text-text-muted"><T id={pricingSection.sub} en={pricingSection.subEn} /></p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-5 items-start">
      {pricingPlans.map((plan, i) => (
        <article
          class={`reveal rounded-[18px] p-8 border transition-all duration-200 hover:-translate-y-1 ${
            plan.featured
              ? 'bg-primary border-primary'
              : 'bg-white dark:bg-dark border-border dark:border-dark-border hover:border-primary'
          }`}
          style={`transition-delay: ${i * 80}ms; ${plan.featured ? 'box-shadow: 0 12px 40px rgba(255,121,27,0.35)' : ''}`}
        >
          {plan.featured && plan.badge && (
            <span class="inline-block bg-white/25 text-white text-[11px] font-extrabold rounded-full px-3 py-1 mb-4">
              <T id={plan.badge} en={plan.badgeEn} />
            </span>
          )}

          <h3 class={`text-xl font-black mb-1.5 ${plan.featured ? 'text-white' : 'text-dark dark:text-white'}`}>
            {plan.name}
          </h3>
          <p class={`text-[13px] mb-5 ${plan.featured ? 'text-white/75' : 'text-text-muted'}`}>
            <T id={plan.desc} en={plan.descEn} />
          </p>

          <div class={`text-[34px] font-black tracking-tight ${plan.featured ? 'text-white' : 'text-dark dark:text-white'}`} style="letter-spacing:-0.05em">
            <span class="price-display">{plan.price.ID}</span>
            {plan.period && (
              <span class={`text-sm font-medium ${plan.featured ? 'text-white/60' : 'text-text-muted'}`}>
                <T id={plan.period} en={plan.periodEn} />
              </span>
            )}
          </div>

          <hr class={`my-5 ${plan.featured ? 'border-white/25' : 'border-border dark:border-dark-border'}`} />

          <ul class="flex flex-col gap-2.5 mb-6">
            {plan.features.map((f, fi) => (
              <li class={`text-[13px] flex items-center gap-2 ${plan.featured ? 'text-white' : 'text-text-body dark:text-text-muted'}`}>
                <span class={`font-black text-sm ${plan.featured ? 'text-white/80' : 'text-primary'}`}>✓</span>
                <T id={f} en={plan.featuresEn[fi] ?? f} />
              </li>
            ))}
          </ul>

          <a
            href={`https://wa.me/${siteConfig.whatsapp.ID}?text=${encodeURIComponent(`Halo TentaKlik! Saya tertarik dengan paket ${plan.name}.`)}`}
            class={`block w-full text-center py-3.5 rounded-xl font-extrabold text-sm tracking-wide transition-colors ${
              plan.featured
                ? 'bg-white text-primary hover:bg-white/90'
                : 'bg-primary text-white hover:bg-primary-dark'
            }`}
            target="_blank"
            rel="noopener noreferrer"
            data-plan={plan.name}
          >
            <T id={plan.cta} en={plan.ctaEn} />
          </a>
        </article>
      ))}
    </div>
  </div>
</section>

<script>
  import { detectRegion } from '@/utils/region';
  import { pricingPlans, siteConfig } from '@/data/content';
  import type { Region } from '@/data/content';

  function applyRegion(region: Region) {
    document.querySelectorAll<HTMLElement>('.price-display').forEach((el, idx) => {
      const plan = pricingPlans[idx];
      if (plan) el.textContent = plan.price[region] ?? plan.price.ID;
    });
    const wa = siteConfig.whatsapp[region];
    document.querySelectorAll<HTMLAnchorElement>('[data-plan]').forEach((el) => {
      const plan = el.dataset.plan ?? '';
      el.href = `https://wa.me/${wa}?text=${encodeURIComponent(`Halo TentaKlik! Saya tertarik dengan paket ${plan}.`)}`;
    });
  }

  applyRegion(detectRegion());
  window.addEventListener('regionchange', (e) => {
    applyRegion((e as CustomEvent<{ region: Region }>).detail.region);
  });
</script>
