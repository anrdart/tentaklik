---
import { heroContent } from '@/data/content';
import T from './T.astro';
---

<section id="beranda" class="relative overflow-hidden">
  <div
    class="absolute inset-0 pointer-events-none"
    style="background-image: radial-gradient(#e5e5e5 1px, transparent 1px); background-size: 28px 28px; opacity: 0.6;"
    aria-hidden="true"
  ></div>

  <div class="relative max-w-container mx-auto px-10 grid grid-cols-1 lg:grid-cols-2 gap-8 items-center py-14" style="min-height: calc(100vh - 68px)">
    <div class="reveal">
      <span class="block text-primary text-sm font-bold tracking-widest uppercase mb-5">
        {heroContent.badge}
      </span>

      <h1 class="text-5xl lg:text-[54px] font-black text-dark leading-[1.1] mb-5" style="letter-spacing: -0.125rem">
        <T id={heroContent.title} en={heroContent.titleEn} />
      </h1>

      <p class="text-base text-text-body leading-relaxed max-w-120 mb-3">
        <T id={heroContent.sub1} en={heroContent.sub1En} />
      </p>
      <p class="text-base text-text-body leading-relaxed max-w-120 mb-9">
        <T id={heroContent.sub2} en={heroContent.sub2En} />
      </p>

      <div class="flex flex-wrap gap-3 mb-6">
        <button
          id="hero-cta"
          class="bg-primary hover:bg-primary-dark text-white font-extrabold text-sm px-8 py-3.5 rounded-lg transition-colors tracking-wider cursor-pointer"
          aria-label="Mulai konsultasi gratis dengan TentaKlik"
        >
          <T id={heroContent.cta} en={heroContent.ctaEn} />
        </button>
        <a
          href="#layanan"
          class="bg-white border-2 border-primary text-primary hover:bg-primary hover:text-white font-bold text-sm px-8 py-3.5 rounded-lg transition-colors tracking-wide"
        >
          <T id={heroContent.ctaSecondary} en={heroContent.ctaSecondaryEn} />
        </a>
      </div>

      <div class="flex flex-wrap gap-6">
        {heroContent.trust.map((t) => (
          <div class="flex items-center gap-2 text-sm text-dark font-semibold">
            <span class="text-primary font-black">✓</span>
            {t}
          </div>
        ))}
      </div>
    </div>

    <div class="reveal flex items-center justify-end">
      <img
        src="/hero.png"
        alt="Portfolio website klien TentaKlik"
        class="w-full max-w-150"
        style="filter: drop-shadow(0 24px 48px rgba(0,0,0,0.15))"
        loading="eager"
        width="600"
        height="480"
      />
    </div>
  </div>
</section>

<script>
  import { fireConfetti } from '@/utils/confetti';
  import { getWhatsAppLink, detectRegion } from '@/utils/region';
  import { siteConfig } from '@/data/content';

  const btn = document.getElementById('hero-cta')!;
  btn.addEventListener('click', async () => {
    await fireConfetti();
    const region = detectRegion();
    window.open(
      getWhatsAppLink(siteConfig.whatsapp, region, 'Halo TentaKlik! Saya ingin konsultasi gratis untuk bisnis saya.'),
      '_blank', 'noopener,noreferrer'
    );
  });
</script>
