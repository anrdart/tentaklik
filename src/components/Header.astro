---
import { navItems, siteConfig } from '@/data/content';
import SettingsDropdown from './SettingsDropdown.astro';
import MobileMenu from './MobileMenu.astro';
import T from './T.astro';
---

<MobileMenu />

<header
  id="site-header"
  class="sticky top-0 z-40 bg-white/95 backdrop-blur-sm border-b border-border transition-shadow duration-200"
>
  <nav class="max-w-container mx-auto px-5 md:px-10 flex items-center justify-between" style="height:68px">
    <!-- Logo -->
    <a href="#beranda" class="flex items-center" aria-label="TentaKlik - Beranda">
      <img
        src="/logo-light.png"
        alt="TentaKlik"
        class="h-9 w-auto logo-light"
        width="160"
        height="36"
      />
      <img
        src="/logo-dark.png"
        alt="TentaKlik"
        class="h-9 w-auto logo-dark"
        width="160"
        height="36"
      />
    </a>

    <!-- Desktop Nav -->
    <ul class="hidden lg:flex items-center gap-7" role="list">
      {navItems.map((item) => (
        <li>
          <a
            href={item.href}
            class="text-sm font-semibold text-text-body dark:text-[#ccc] hover:text-primary transition-colors"
          >
            <T id={item.label} en={item.labelEn} />
          </a>
        </li>
      ))}
    </ul>

    <!-- Desktop Right Actions -->
    <div class="hidden lg:flex items-center gap-3">
      <SettingsDropdown />
      <a
        id="nav-wa-cta"
        href={`https://wa.me/${siteConfig.whatsapp.ID}?text=${encodeURIComponent('Halo TentaKlik, saya ingin konsultasi gratis.')}`}
        target="_blank"
        rel="noopener noreferrer"
        class="bg-primary hover:bg-primary-dark text-white font-extrabold text-sm px-6 py-2.5 rounded-lg transition-colors tracking-wide"
      >
        <T id="KONSULTASI GRATIS" en="FREE CONSULTATION" />
      </a>
    </div>

    <!-- Mobile Hamburger -->
    <button
      id="mobile-menu-open"
      aria-label="Buka menu navigasi"
      class="lg:hidden flex flex-col items-center justify-center gap-1.5 w-10 h-10 cursor-pointer"
    >
      <span class="w-6 h-0.5 bg-dark dark:bg-white block"></span>
      <span class="w-6 h-0.5 bg-dark dark:bg-white block"></span>
      <span class="w-4 h-0.5 bg-dark dark:bg-white block self-start"></span>
    </button>
  </nav>
</header>

<script>
  import { detectRegion } from '@/utils/region';
  import { siteConfig } from '@/data/content';
  import type { Region } from '@/data/content';

  // Add shadow on scroll
  const header = document.getElementById('site-header')!;
  window.addEventListener('scroll', () => {
    header.classList.toggle('shadow-sm', window.scrollY > 10);
  }, { passive: true });

  // Open mobile menu
  document.getElementById('mobile-menu-open')!.addEventListener('click', () => {
    const menu = document.getElementById('mobile-menu')!;
    menu.classList.remove('translate-x-full');
    menu.setAttribute('aria-hidden', 'false');
  });

  // Update nav CTA WhatsApp link on regionchange
  function updateNavCta(region: Region) {
    const link = document.getElementById('nav-wa-cta') as HTMLAnchorElement | null;
    if (link) {
      link.href = `https://wa.me/${siteConfig.whatsapp[region]}?text=${encodeURIComponent('Halo TentaKlik, saya ingin konsultasi gratis.')}`;
    }
  }

  updateNavCta(detectRegion());
  window.addEventListener('regionchange', (e) => {
    updateNavCta((e as CustomEvent<{ region: Region }>).detail.region);
  });
</script>
