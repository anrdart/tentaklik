---
import { testimonials, testimonialsSection } from '@/data/content';
import T from './T.astro';
---

<section id="testimoni" class="py-20 bg-surface dark:bg-dark">
  <div class="max-w-container mx-auto px-10">
    <div class="reveal">
      <p class="eyebrow"><T id={testimonialsSection.eyebrow} en={testimonialsSection.eyebrowEn} /></p>
      <h2 class="section-title dark:text-white"><T id={testimonialsSection.title} en={testimonialsSection.titleEn} /></h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
      {testimonials.map((t, i) => (
        <article
          class="reveal bg-white dark:bg-dark-card border border-border dark:border-dark-border rounded-2xl p-7 hover:border-primary transition-all duration-200"
          style={`transition-delay: ${i * 60}ms`}
        >
          <div class="flex gap-0.5 mb-4" aria-label={`Rating ${t.stars} bintang`}>
            {Array.from({ length: t.stars }).map(() => (
              <span class="text-primary text-lg" aria-hidden="true">★</span>
            ))}
          </div>
          <blockquote class="text-[15px] leading-relaxed italic mb-5 text-dark/80 dark:text-white/70">
            "<T id={t.quote} en={t.quoteEn} />"
          </blockquote>
          <div class="flex items-center gap-3">
            <div class="w-11 h-11 rounded-full bg-primary flex items-center justify-center text-white text-sm font-extrabold flex-shrink-0" aria-hidden="true">
              {t.initials}
            </div>
            <div>
              <p class="text-sm font-extrabold text-dark dark:text-white">{t.name}</p>
              <p class="text-xs text-text-muted">{t.role}</p>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
