---
import { services, servicesSection } from '@/data/content';
import T from './T.astro';
---

<section id="layanan" class="py-12 md:py-20 bg-white dark:bg-dark-card">
  <div class="max-w-container mx-auto px-5 md:px-10">
    <div class="reveal">
      <p class="eyebrow"><T id={servicesSection.eyebrow} en={servicesSection.eyebrowEn} /></p>
      <h2 class="section-title max-w-xl dark:text-white"><T id={servicesSection.title} en={servicesSection.titleEn} /></h2>
      <p class="section-sub dark:text-text-muted"><T id={servicesSection.sub} en={servicesSection.subEn} /></p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
      {services.map((s, i) => (
        <article
          class="reveal border border-border dark:border-dark-border rounded-2xl p-6 bg-white dark:bg-dark-card hover:border-primary hover:-translate-y-1 transition-all duration-200 cursor-default group"
          style={`transition-delay: ${i * 40}ms`}
        >
          <div class="w-11.5 h-11.5 bg-primary-light rounded-xl flex items-center justify-center text-2xl mb-4">
            {s.icon}
          </div>
          <span class="inline-block text-[10px] font-extrabold text-primary bg-primary-light rounded-full px-3 py-0.5 mb-3 tracking-wide">
            <T id={s.tag} en={s.tagEn} />
          </span>
          <h3 class="text-[15px] font-extrabold text-dark dark:text-white mb-2">
            <T id={s.title} en={s.titleEn} />
          </h3>
          <p class="text-[13px] text-text-body dark:text-text-muted leading-relaxed">
            <T id={s.desc} en={s.descEn} />
          </p>
        </article>
      ))}
    </div>
  </div>
</section>
