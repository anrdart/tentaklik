---
import { processSteps, processSection } from '@/data/content';
import T from './T.astro';
---

<section id="proses" class="py-20 bg-surface dark:bg-dark">
  <div class="max-w-container mx-auto px-10">
    <div class="reveal">
      <p class="eyebrow"><T id={processSection.eyebrow} en={processSection.eyebrowEn} /></p>
      <h2 class="section-title dark:text-white"><T id={processSection.title} en={processSection.titleEn} /></h2>
      <p class="section-sub dark:text-text-muted"><T id={processSection.sub} en={processSection.subEn} /></p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {processSteps.map((step, i) => (
        <div
          class="reveal bg-white dark:bg-dark-card border border-border dark:border-dark-border rounded-2xl p-7 hover:border-primary hover:-translate-y-1 transition-all duration-200"
          style={`transition-delay: ${i * 60}ms`}
        >
          <div class="text-5xl font-black text-primary-light tracking-tighter mb-4 leading-none select-none">
            {step.num}
          </div>
          <h3 class="text-base font-extrabold text-dark dark:text-white mb-2">
            <T id={step.title} en={step.titleEn} />
          </h3>
          <p class="text-[13px] text-text-body dark:text-text-muted leading-relaxed">
            <T id={step.desc} en={step.descEn} />
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
