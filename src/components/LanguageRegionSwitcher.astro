---
---
<div class="flex items-center gap-2">
  <button
    id="lang-toggle"
    aria-label="Ganti bahasa / Switch language"
    class="flex items-center gap-1.5 border border-border rounded-md px-2.5 py-1.5 text-xs font-bold text-text-body cursor-pointer hover:border-primary hover:text-primary transition-colors bg-transparent"
  >
    <span id="lang-flag">🇮🇩</span>
    <span id="lang-label">ID</span>
  </button>
</div>

<script>
  import { detectLang, setLang } from '@/utils/i18n';
  import { detectAndSetRegionFromIP } from '@/utils/region';
  import type { Lang } from '@/utils/i18n';

  const btn = document.getElementById('lang-toggle')!;
  const flagEl = document.getElementById('lang-flag')!;
  const labelEl = document.getElementById('lang-label')!;

  const FLAGS: Record<Lang, string> = { id: '🇮🇩', en: '🇬🇧' };
  const LABELS: Record<Lang, string> = { id: 'ID', en: 'EN' };

  function updateBtn(lang: Lang) {
    flagEl.textContent = FLAGS[lang];
    labelEl.textContent = LABELS[lang];
  }

  const currentLang = detectLang();
  updateBtn(currentLang);
  // CSS already handled by inline script in BaseLayout head

  btn.addEventListener('click', () => {
    const next: Lang = detectLang() === 'id' ? 'en' : 'id';
    setLang(next);
    updateBtn(next);
  });

  detectAndSetRegionFromIP();
</script>
